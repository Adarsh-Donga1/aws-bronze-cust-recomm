# Copy to ".env" and adjust values. ".env" is gitignored.
# local_run.py loads .env automatically if python-dotenv is installed.

# -----------------------------------------------------------------------------
# AWS authentication (use one approach)
# -----------------------------------------------------------------------------
# Named profile from ~/.aws/credentials
# AWS_PROFILE=default

# Optional: JSON secret in Secrets Manager (keys: aws_access_key_id, aws_secret_access_key, optional aws_session_token)
# FINOMICS_AWS_CREDENTIALS_SECRET=finomics/aws/bronze-ingestion-keys

# Optional: absolute path to a local JSON file with the same keys (alternative to env keys below)
# BRONZE_AWS_CREDS_FILE=

# If you use `aws sso login` or rely on ~/.aws/credentials, do NOT set the three keys below
# in this file — a stale AWS_SESSION_TOKEN here overrides your fresh CLI session and causes ExpiredToken.
# To force using profile/SSO for local_run, set:
# BRONZE_USE_PROFILE_CREDENTIALS=true
# Or: python local_run.py --use-profile-creds --aws-profile your-sso-profile

# Or static keys (avoid committing real secrets; prefer SSO / profile)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Default region for boto3 and local_run when --regions is omitted
AWS_REGION=us-east-1
# AWS_DEFAULT_REGION=us-east-1

# Multi-region (comma-separated). Used by Glue job param AWS_REGIONS; optional locally.
# AWS_REGIONS=us-east-1,us-west-2

# Optional: 12-digit account. If unset, STS get_caller_identity is used.
# AWS_ACCOUNT_ID=123456789012

# -----------------------------------------------------------------------------
# Finomics metadata (stamped on bronze rows)
# -----------------------------------------------------------------------------
CLIENT_ID=your-client-or-tenant-id

# Optional second client_id duplicated in Iceberg (Glue: ADDITIONAL_CLIENT_ID)
# ADDITIONAL_CLIENT_ID=

# -----------------------------------------------------------------------------
# Glue job parameters (reference — Glue passes these as job arguments, not .env)
# Uncomment to mirror what you set on the Glue job for local documentation.
# -----------------------------------------------------------------------------
# JOB_NAME=aws-ec2-bronze-ingestion
# WINDOW_DAYS=7
# ACTIVE_SERVICES=EC2
# S3_BUCKET=your-s3-bucket-for-iceberg-warehouse
# ICEBERG_DATABASE=bronze
# ICEBERG_CATALOG=glue_catalog

# -----------------------------------------------------------------------------
# Local runner overrides (optional — CLI flags win if passed)
# -----------------------------------------------------------------------------
# LOCAL_SERVICES=EC2
# LOCAL_WINDOW_DAYS=2
# LOCAL_MAX_RESOURCES=0

# local_run.py file export (optional; enables --export-json / --export-csv without CLI flags)
# LOCAL_EXPORT_JSON=true
# LOCAL_EXPORT_CSV=true
# LOCAL_EXPORT_DIR=output
# LOCAL_EXPORT_QUIET=true
